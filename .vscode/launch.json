                "${file}",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pytest: 当前方法",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}::${selectedText}",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pytest: 全部测试",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "testcases",
                "-v",
                "--html=reports/report.html"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Pytest: Smoke测试",
            "type": "debugpy",
